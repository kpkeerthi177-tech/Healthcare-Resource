import { motion } from 'framer-motion';
import { useAuth, UserRole } from '@/contexts/AuthContext';
import { Shield, Building2, Ambulance, Users, Heart } from 'lucide-react';

const roles: { role: UserRole; label: string; icon: typeof Shield; description: string }[] = [
  { role: 'hospital', label: 'Hospital Staff', icon: Building2, description: 'Manage beds, facilities & team readiness' },
  { role: 'ambulance', label: 'Ambulance / Paramedic', icon: Ambulance, description: 'Dispatch, patient vitals & navigation' },
  { role: 'patient', label: 'Patient', icon: Heart, description: 'SOS alerts, health profile & appointments' },
  { role: 'family', label: 'Family Member', icon: Users, description: 'Track ambulance & view hospital info' },
];

export default function LoginPage() {
  const { login } = useAuth();

  return (
    <div className="min-h-screen flex items-center justify-center bg-background p-4">
      <motion.div
        initial={{ opacity: 0, y: 30 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ duration: 0.5 }}
        className="w-full max-w-lg"
      >
        <div className="text-center mb-10">
          <div className="inline-flex items-center justify-center w-16 h-16 rounded-2xl gradient-navy mb-4">
            <Shield className="h-8 w-8 text-medical-blue" />
          </div>
          <h1 className="text-3xl font-bold text-foreground tracking-tight">MedLink</h1>
          <p className="text-muted-foreground mt-2">Smart Hospital & Ambulance Coordination</p>
        </div>

        <div className="space-y-3">
          {roles.map((r, i) => (
            <motion.button
              key={r.role}
              initial={{ opacity: 0, x: -20 }}
              animate={{ opacity: 1, x: 0 }}
              transition={{ duration: 0.3, delay: i * 0.1 }}
              onClick={() => login(r.role)}
              className="w-full glass-card-elevated rounded-xl p-4 flex items-center gap-4 hover:border-medical-blue/40 hover:shadow-md transition-all duration-150 group text-left"
            >
              <div className="rounded-lg p-2.5 bg-medical-blue/10 text-medical-blue group-hover:bg-medical-blue group-hover:text-medical-blue-foreground transition-colors duration-150">
                <r.icon className="h-5 w-5" />
              </div>
              <div>
                <p className="font-semibold text-foreground">{r.label}</p>
                <p className="text-sm text-muted-foreground">{r.description}</p>
              </div>
            </motion.button>
          ))}
        </div>

        <p className="text-center text-xs text-muted-foreground mt-8">
          Demo mode — select a role to explore the dashboard
        </p>
      </motion.div>
    </div>
  );
}
